:root {
  --bg-color: #050505;
  --panel-bg: rgba(20, 20, 20, 0.9); /* More solid background for high visibility */
  --text-primary: #F5F5DC;
  --text-secondary: rgba(245, 245, 220, 0.7);
  --accent-color: #C0392B;
  --accent-glow: rgba(192, 57, 43, 0.6);
  --font-heading: 'Oswald', sans-serif;
  --font-body: 'Inter', sans-serif;
  --transition-smooth: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: var(--font-body);
  line-height: 1.7;
  overflow-x: hidden;
  position: relative;
  background-image: radial-gradient(circle at center, #111 0%, #000 100%);
}

.pizza-icons-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 0;
  perspective: 1000px;
  overflow: hidden;
}

.floating-wrapper {
  position: absolute;
  transform-style: preserve-3d;
  will-change: transform;
}

/* Made floating pizzas highly visible per user request */
.floating-icon {
  width: 100%;
  height: auto;
  opacity: 0.7; 
  filter: drop-shadow(0 20px 30px rgba(0,0,0,0.8));
  will-change: transform;
  transition: transform 0.1s linear;
}

.navbar {
  position: fixed;
  top: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 6%;
  background: linear-gradient(to bottom, rgba(5,5,5,1) 0%, rgba(5,5,5,0.7) 60%, rgba(5,5,5,0) 100%);
  z-index: 1000;
  transition: padding 0.3s ease;
}

.navbar.scrolled {
  padding: 1rem 6%;
  background: rgba(5, 5, 5, 0.95);
  backdrop-filter: blur(15px);
  border-bottom: 1px solid rgba(192, 57, 43, 0.3);
}

.logo {
  font-family: var(--font-heading);
  font-size: min(5vw, 1.8rem);
  font-weight: 500;
  letter-spacing: 2px;
}
.logo-red {
  color: var(--accent-color);
  font-weight: 700;
}

.call-btn {
  background: transparent;
  color: var(--text-primary);
  text-decoration: none;
  padding: 0.6rem 1.5rem;
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: min(3.5vw, 1rem);
  letter-spacing: 1px;
  border: 1px solid rgba(245,245,220,0.2);
  border-radius: 50px;
  transition: var(--transition-smooth);
  display: flex;
  align-items: center;
  backdrop-filter: blur(5px);
}

.call-btn:hover {
  background: var(--accent-color);
  border-color: var(--accent-color);
  box-shadow: 0 0 20px var(--accent-glow);
  transform: translateY(-2px);
  color: #fff;
}

.hero {
  position: relative;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  z-index: 1;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  top: -10%; left: -10%; right: -10%; bottom: -10%;
  background: url('assets/hero_pizza.webp') center/cover no-repeat;
  z-index: -2;
  will-change: transform;
}

.hero-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(circle at center, rgba(0,0,0,0.5) 0%, rgba(5,5,5,1) 100%);
  z-index: -1;
}

.hero-content {
  position: relative;
  z-index: 3;
  padding: 0 20px;
  transform-style: preserve-3d;
}

/* Fully responsive hero font sizing */
.hero h1 {
  font-family: var(--font-heading);
  font-size: min(15vw, 6rem);
  line-height: 1.1;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  color: var(--accent-color);
  text-shadow: 0 10px 30px rgba(0,0,0,1);
  letter-spacing: min(1vw, 5px);
}

.hero-sub {
  display: block;
  font-size: min(5vw, 1.5rem);
  color: var(--text-primary);
  letter-spacing: min(2vw, 10px);
  margin-top: 10px;
  font-weight: 300;
}

.hero p {
  font-size: min(4vw, 1.2rem);
  margin-bottom: 2rem;
  font-weight: 300;
  letter-spacing: 1px;
  color: #fff;
}

.primary-cta {
  display: inline-block;
  background-color: var(--accent-color);
  color: #fff;
  text-decoration: none;
  padding: 1rem 3rem;
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: 2px;
  border-radius: 4px;
  transition: var(--transition-smooth);
  box-shadow: 0 10px 30px rgba(192, 57, 43, 0.4);
  position: relative;
  overflow: hidden;
}

.primary-cta::after {
  content: "";
  position: absolute;
  top: 0; left: -100%;
  width: 50%; height: 100%;
  background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0) 100%);
  transform: skewX(-25deg);
  animation: shine 5s infinite;
}

.primary-cta:hover {
  background-color: #A02D22;
  transform: translateY(-5px);
  box-shadow: 0 15px 40px rgba(192, 57, 43, 0.7);
}

.content-wrapper {
  position: relative;
  z-index: 5;
  background: var(--bg-color);
  padding: 0 5% 6rem 5%;
  max-width: 1400px;
  margin: 0 auto;
}

.menu-header {
  text-align: center;
  padding: 5rem 0 3rem;
}
.grand-title {
  font-family: var(--font-heading);
  font-size: min(10vw, 3.5rem);
  color: var(--text-primary);
  letter-spacing: 4px;
  margin-bottom: 20px;
}
.divider {
  width: 80px;
  height: 4px;
  background: var(--accent-color);
  margin: 0 auto;
  box-shadow: 0 0 10px var(--accent-glow);
}

.section-title {
  font-family: var(--font-heading);
  color: var(--accent-color);
  font-size: min(7vw, 2rem);
  letter-spacing: 2px;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 15px;
  text-transform: uppercase;
}
.section-title::after {
  content: "";
  flex: 1;
  height: 2px;
  background: linear-gradient(to right, rgba(192,57,43,0.8), transparent);
}

.tilt-card {
  transform-style: preserve-3d;
  will-change: transform;
  transition: box-shadow 0.3s ease;
}

.menu-section {
  margin-bottom: 8rem;
  position: relative;
  padding: 4rem 2rem;
  border-radius: 20px;
  overflow: hidden;
}

/* Background Photo Layers for each section */
.menu-section::before {
  content: "";
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  opacity: 0.15; /* Subtle background */
  z-index: -1;
  filter: grayscale(100%) contrast(120%);
}

#signature-pies::before { background-image: url('assets/photo1.jpg'); }
#premium-pies::before { background-image: url('assets/photo2.jpg'); }
#sides-dips::before { background-image: url('assets/photo3.jpg'); }
#drinks::before { background-image: url('assets/photo4.jpg'); }
#desserts::before { background-image: url('assets/photo7.jpg'); }
#reviews-section::before { background-image: url('assets/photo5.jpg'); }
#instagram-section::before { background-image: url('assets/photo6.jpg'); }

.reviews-section, .instagram-section {
  position: relative;
  padding: 4rem 2rem;
  border-radius: 20px;
  overflow: hidden;
  margin-bottom: 2rem;
}

.reviews-section::before, .instagram-section::before {
  content: "";
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  opacity: 0.2; /* Slightly more visible for these sections */
  z-index: -1;
  filter: grayscale(100%) contrast(120%);
}

/* High visibility panel boxes */
.menu-item {
  background: var(--panel-bg);
  border: 1px solid rgba(192, 57, 43, 0.4);
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  position: relative;
}

.item-header {
  display: flex;
  flex-direction: column;
  border-bottom: 1px dashed rgba(245,245,220,0.3);
  padding-bottom: 1rem;
  margin-bottom: 1rem;
  transform: translateZ(30px);
}
@media(min-width: 600px) {
  .item-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
  }
}

.item-header h4 {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  letter-spacing: 1px;
  color: var(--text-primary);
  text-transform: uppercase;
  margin-bottom: 5px;
}
@media(min-width: 600px) {
  .item-header h4 { margin-bottom: 0; }
}

.price {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  color: var(--accent-color);
  font-weight: 700;
  white-space: nowrap;
}

.desc {
  font-size: 0.95rem;
  color: #fff;
  line-height: 1.6;
  transform: translateZ(20px);
}

.add-on {
  margin-top: 0.8rem;
  font-size: 0.85rem;
  text-transform: uppercase;
  color: #e74c3c;
  letter-spacing: 1px;
  font-weight: 600;
  transform: translateZ(25px);
}

/* Social Proof Sections */
.social-proof-container {
  display: block;
  margin-top: 4rem;
  padding-top: 4rem;
  border-top: 2px solid rgba(192,57,43,0.3);
}

.sp-wrapper {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4rem;
}
@media(min-width: 1000px) {
  .sp-wrapper { grid-template-columns: 1fr 1.2fr; }
}

.reviews-section, .instagram-section {
  text-align: left;
}
.reviews-section .grand-title, .instagram-section .grand-title {
  font-size: min(8vw, 2.2rem);
  margin-bottom: 10px;
}
.reviews-section .divider, .instagram-section .divider {
  margin: 0 0 30px 0;
  width: 50px;
}

/* Reviews */
#reviews-container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

.rating-badge {
  display: inline-block;
  padding: 1rem 1.5rem;
  background: rgba(243, 156, 18, 0.1);
  border: 2px solid #f39c12;
  color: #f39c12;
  font-family: var(--font-heading);
  letter-spacing: 1px;
  border-radius: 50px;
  margin-top: 1rem;
  font-size: min(4vw, 1.1rem);
  text-align: center;
}

/* Instagram Grid */
.ig-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}
@media(max-width: 500px) {
  .ig-grid { grid-template-columns: 1fr; }
}

/* Footer Section */
.site-footer {
  background: #000;
  padding: 4rem 5% 3rem;
  border-top: 3px solid var(--accent-color);
  position: relative;
  z-index: 10;
}

.footer-content {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  text-align: center;
}
@media(min-width: 768px) {
  .footer-content {
    grid-template-columns: repeat(3, 1fr);
    text-align: left;
  }
}

.footer-col {
  background: rgba(25,25,25,0.8);
  padding: 2rem;
  border-radius: 12px;
  border: 1px solid rgba(192, 57, 43, 0.3);
}

.footer-col h3 {
  font-family: var(--font-heading);
  color: var(--accent-color);
  font-size: 1.3rem;
  letter-spacing: 2px;
  margin-bottom: 1rem;
}

.footer-col p, .footer-col a {
  color: var(--text-primary);
  font-size: 1rem;
  line-height: 1.8;
  text-decoration: none;
  display: block;
}

.footer-col a {
  margin-top: 1rem;
  transition: color 0.3s ease;
}
.footer-col a:hover {
  color: var(--accent-color);
}

.call-btn-small {
  display: inline-block;
  border: 2px solid var(--accent-color);
  background: rgba(192, 57, 43, 0.1);
  padding: 0.8rem 1.5rem;
  color: #fff !important;
  font-family: var(--font-heading);
  letter-spacing: 1px;
  border-radius: 8px;
}
.call-btn-small:hover {
  background: var(--accent-color);
}

/* General Animations */
.slide-up {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.slide-up.visible {
  opacity: 1;
  transform: translateY(0);
}

.delay-1 { transition-delay: 0.1s; }
.delay-2 { transition-delay: 0.2s; }
.delay-3 { transition-delay: 0.3s; }

.pulse-fast {
  animation: pulseGlowing 2s infinite;
}

@keyframes pulseGlowing {
  0% { box-shadow: 0 0 0 0 rgba(192, 57, 43, 0.6); }
  70% { box-shadow: 0 0 0 15px rgba(192, 57, 43, 0); }
  100% { box-shadow: 0 0 0 0 rgba(192, 57, 43, 0); }
}

@keyframes floatBackground {
  0% { transform: translateY(110vh); }
  100% { transform: translateY(-30vh); }
}
